# Comma-separated list of allowed frontend origins for CORS.
# Required when frontend is on a different domain (e.g. Vercel). Example:
# CORS_ORIGINS=https://pokerpsych.vercel.app,https://pokerpsych-git-main-you.vercel.app
# For local dev with Vite default port:
# CORS_ORIGINS=http://localhost:5173

# Optional: port for the Flask server (default 5001). Useful on PaaS (e.g. Railway sets PORT).
# PORT=5001
